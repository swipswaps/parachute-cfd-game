; Engine configuration file.
; Parachute CFD Landing Game

config_version=5

[application]

config/name="Parachute CFD Landing Game"
config/description="Land accurately using real-time CFD wind visualization"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2

[physics]

3d/default_gravity=9.81
3d/default_linear_damp=0.1
3d/default_angular_damp=0.1

[rendering]

renderer/rendering_method="forward_plus"
anti_aliasing/quality/msaa_3d=2
; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Parachute Landing Pattern v314"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6")
boot_splash="res://assets/boot_splash.png"
boot_splash_bg_color=Color(0, 0, 0, 1)

[autoload]

SqliteDb="*res://scripts/SqliteDb.gd"
DatabaseGuard="*res://scripts/DatabaseGuard.gd"
ResourceThrottle="*res://scripts/ResourceThrottle.gd"
PerformanceMonitor="*res://scripts/PerformanceMonitor.gd"
aero_units="*res://addons/godot_aerodynamic_physics/core/singletons/aero_units.gd"
#Databaseinfrastructure-LOADFIRST#CoredatabaseSqliteWatchdog="*res://scripts/SqliteWatchdog.gd"
#Monitoring(usesDatabaseGuardandResourceThrottle)#LoggingandutilitiesStructuredLogger="*res://scripts/StructuredLogger.gd"
InputManager="*res://scripts/InputManager.gd"
GameIntegrity="*res://scripts/GameIntegrity.gd"
#HUDandUIAltimeterHUD="*res://scripts/altimeter_hud.gd"
ForensicHUD="*res://scripts/forensic_hud.gd"
Audit="*res://scripts/audit.gd"
#PhysicsandenvironmentWindField="*res://scripts/wind_field.gd"
AeroUnits="*uid://5vah4ayrdxci"

[editor_plugins]

plugins/godot-sqlite/plugin.cfg="*"

[environment]

defaults/default_environment=""
ambient_light/color=Color(1, 1, 1, 1)
ambient_light/energy=1.0
defaults/default_clear_color=Color(0.3, 0.5, 0.7, 1)

[gdextension]

path="res://addons/godot-sqlite/gdsqlite.gdextension"

